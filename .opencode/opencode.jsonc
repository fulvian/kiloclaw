{
  "$schema": "https://app.kilo.ai/config.json",
  // "enterprise": {
  //   "url": "https://enterprise.dev.opencode.ai",
  // },
  "provider": {
    "kilo": {
      "options": {},
    },
  },
  "permission": {
    "edit": {
      "packages/opencode/migration/*": "deny",
    },
  },
  "mcp": {
    "google-workspace": {
      "type": "remote",
      "url": "http://localhost:8000/mcp",
      "enabled": true,
      "oauth": {},
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
